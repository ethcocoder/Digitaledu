rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()  { return request.auth != null; }

    // ────── PUBLIC access for landing/catalog ──────

    match /courses/{courseId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && request.auth.uid == resource.data.instructorId;
    }

    match /platformSettings/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /users/{uid} {
      allow read: if true;
      allow create: if request.auth.uid == uid;
      allow update: if isAuth();
      allow delete: if isAuth() && request.auth.uid == uid;
    }

    match /enrollments/{eid} {
      allow read, list: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth();
    }

    match /userProgress/{uid} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if isAuth();
      allow delete: if isAuth() && request.auth.uid == uid;
    }
  }
}
