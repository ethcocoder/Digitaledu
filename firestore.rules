rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function userDoc() {
      let doc = get(/databases/$(database)/documents/users/$(request.auth.uid));
      return doc.exists ? doc.data : null;
    }

    function role() {
      let data = userDoc();
      return data != null ? data.role : null;
    }

    function isSuperAdmin() {
      return role() == 'superadmin';
    }

    function isAdmin() {
      let r = role();
      return r == 'admin' || r == 'superadmin';
    }

    function isInstructor() {
      return role() == 'instructor';
    }

    function isCourseOwner(course) {
      return isAuthenticated() && course.instructorId == request.auth.uid;
    }

    // Allowed status transitions for course owners
    function ownerCanSetStatus(newStatus, oldStatus) {
      return newStatus == oldStatus ||
             newStatus == 'pending_review' ||
             newStatus == 'archived';
    }

    // Allowed statuses for students to see
    function isPublished(data) {
      return data.status == 'approved' || data.status == 'published';
    }

    // ─── Users ──────────────────────────────────────────────

    match /users/{userId} {
      allow create: if isAuthenticated();
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ─── Courses ────────────────────────────────────────────

    match /courses/{courseId} {
      // Read: published (public), course owner, or admin
      allow read: if isPublished(resource.data) ||
        isCourseOwner(resource.data) ||
        isAdmin();

      allow list: if isAuthenticated();

      // Create: instructor, must start as draft
      allow create: if isAuthenticated() &&
        request.resource.data.instructorId == request.auth.uid &&
        request.resource.data.status == 'draft';

      // Update:
      //   Admin/superadmin → full access (approve/reject/anything)
      //   Course owner → content editing + allowed status transitions
      allow update: if isAuthenticated() && (
        isAdmin() ||
        (isCourseOwner(resource.data) &&
         ownerCanSetStatus(request.resource.data.status, resource.data.status))
      );

      allow delete: if isSuperAdmin();
    }

    // ─── Platform Settings ──────────────────────────────────

    match /platformSettings/{docId} {
      allow read: if isAuthenticated();
      allow write: if isSuperAdmin();
    }

    // ─── Enrollments ────────────────────────────────────────

    match /enrollments/{enrollmentId} {
      allow read, list: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.instructorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated() &&
        request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── User Progress (gamification) ───────────────────────

    match /userProgress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if isSuperAdmin();
    }

    // ─── Catch-all ──────────────────────────────────────────

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
