rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Function to check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Function to check if the user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Function to check if the user is a superadmin
    function isSuperAdmin() {
      return isAuthenticated() && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    // Function to check if the user is an admin
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || isSuperAdmin());
    }

    // ---------------------------------------------------------
    // Users Collection Rules
    // ---------------------------------------------------------
    match /users/{userId} {
      // Anyone can create their profile when they first sign up (must match their auth UID)
      allow create: if isOwner(userId);
      
      // Users can read and update their own profile. Admins/Superadmins can read all.
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can update their own profile (but shouldn't be able to change their role easily, 
      // though we'll keep it simple for now). Admins can update all.
      allow update: if isOwner(userId) || isAdmin();
      
      // Only Superadmins can delete users
      allow delete: if isSuperAdmin();
    }
    
    // Default deny for any other collections we haven't defined yet
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
