rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAuth() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'superadmin';
    }

    function isAdmin() {
      return isAuth() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'superadmin']);
    }

    // Instructor can only transition to these statuses (no self-approval)
    function instructorAllowedStatus(newStatus) {
      return newStatus == 'draft' || newStatus == 'pending_review' || newStatus == 'archived';
    }

    // ---------------------------------------------------------
    // Users Collection
    // ---------------------------------------------------------
    match /users/{userId} {
      allow create: if isOwner(userId);
      allow read: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isSuperAdmin();
    }

    // ---------------------------------------------------------
    // Courses Collection
    // ---------------------------------------------------------
    match /courses/{courseId} {
      // Read: approved/published are public-ish; owner/admin see all
      allow read: if isAuth() && (
        resource.data.status == 'approved' ||
        resource.data.status == 'published' ||
        resource.data.instructorId == request.auth.uid ||
        isAdmin()
      );

      // Create: instructor must own it, must start as draft
      allow create: if isAuth() &&
        request.resource.data.instructorId == request.auth.uid &&
        request.resource.data.status == 'draft';

      // Update:
      //   - Owner (instructor): can update any field except status cannot be 'approved'/'rejected'
      //   - Admin/superadmin: full access
      allow update: if isAuth() && (
        (
          resource.data.instructorId == request.auth.uid &&
          instructorAllowedStatus(request.resource.data.status)
        ) ||
        isAdmin()
      );

      allow delete: if isSuperAdmin();
    }

    // ---------------------------------------------------------
    // Platform Settings (global config)
    // ---------------------------------------------------------
    match /platformSettings/{docId} {
      allow read: if isAuth();
      allow write: if isSuperAdmin();
    }

    // ---------------------------------------------------------
    // Enrollments Collection
    // ---------------------------------------------------------
    match /enrollments/{enrollmentId} {
      allow read: if isAuth() && (
        resource.data.studentId == request.auth.uid ||
        resource.data.instructorId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuth() &&
        request.resource.data.studentId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.studentId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ---------------------------------------------------------
    // User Progress (gamification)
    // ---------------------------------------------------------
    match /userProgress/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
